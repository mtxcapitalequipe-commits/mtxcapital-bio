<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= profile.name %> — Links</title>
  <meta name="description" content="<%= profile.name %> — <%= profile.tagline %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    /* ── Reset & Base ──────────────────────────────── */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --orange: #ff6b35;
      --red: #dd3b30;
      --black: #1a1a1a;
      --off-white: #f5f5f0;
      --gradient: linear-gradient(135deg, var(--orange), var(--red));
    }

    html { font-size: 16px; }

    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--black);
      color: var(--off-white);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow-x: hidden;
      position: relative;
    }

    /* ── Background Texture ────────────────────────── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 60% at 50% -10%, rgba(255,107,53,0.12) 0%, transparent 60%),
        radial-gradient(ellipse 60% 50% at 80% 100%, rgba(221,59,48,0.08) 0%, transparent 50%);
      pointer-events: none;
      z-index: 0;
    }

    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
    }

    /* ── Container ─────────────────────────────────── */
    .container {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 420px;
      padding: 48px 20px 60px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 36px;
    }

    /* ── Logo ──────────────────────────────────────── */
    .logo-wrap {
      position: relative;
      width: 110px;
      height: 110px;
      opacity: 0;
      animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.1s forwards;
    }

    .logo-circle {
      width: 110px;
      height: 110px;
      border-radius: 50%;
      overflow: hidden;
      position: relative;
    }

    .logo-circle img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* ── Profile ───────────────────────────────────── */
    .profile {
      text-align: center;
      display: flex;
      flex-direction: column;
      gap: 6px;
      opacity: 0;
      animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.25s forwards;
    }

    .profile-name {
      font-family: 'Inter', sans-serif;
      font-size: 1.6rem;
      font-weight: 700;
      letter-spacing: 3px;
      background: var(--gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Divider ───────────────────────────────────── */
    .divider {
      width: 40px;
      height: 2px;
      background: var(--gradient);
      border: none;
      border-radius: 1px;
      opacity: 0;
      animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.35s forwards;
    }

    /* ── Links ─────────────────────────────────────── */
    .links {
      display: flex;
      flex-direction: column;
      gap: 14px;
      width: 100%;
    }

    .link-card {
      opacity: 0;
      animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .link-card:nth-child(1) { animation-delay: 0.45s; }
    .link-card:nth-child(2) { animation-delay: 0.55s; }
    .link-card:nth-child(3) { animation-delay: 0.65s; }
    .link-card:nth-child(4) { animation-delay: 0.75s; }
    .link-card:nth-child(5) { animation-delay: 0.85s; }

    .link-card a {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 18px 22px;
      background: rgba(245,245,240,0.04);
      border: 1px solid rgba(245,245,240,0.07);
      border-radius: 14px;
      text-decoration: none;
      color: var(--off-white);
      transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
      position: relative;
      overflow: hidden;
    }

    .link-card a::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--gradient);
      opacity: 0;
      transition: opacity 0.35s ease;
      z-index: 0;
    }

    .link-card a:hover {
      border-color: rgba(255,107,53,0.3);
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(255,107,53,0.15);
    }

    .link-card a:hover::before {
      opacity: 0.08;
    }

    .link-card a:active {
      transform: translateY(0);
    }

    .link-icon {
      position: relative;
      z-index: 1;
      width: 42px;
      height: 42px;
      border-radius: 10px;
      background: rgba(245,245,240,0.06);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: background 0.35s ease;
    }

    .link-card a:hover .link-icon {
      background: rgba(255,107,53,0.15);
    }

    .link-icon svg {
      width: 20px;
      height: 20px;
      fill: none;
      stroke: var(--orange);
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .link-text {
      position: relative;
      z-index: 1;
      flex: 1;
    }

    .link-title {
      font-weight: 700;
      font-size: 0.95rem;
      margin-bottom: 2px;
    }

    .link-desc {
      font-size: 0.75rem;
      color: rgba(245,245,240,0.4);
      font-weight: 400;
    }

    .link-arrow {
      position: relative;
      z-index: 1;
      opacity: 0.3;
      transition: all 0.35s ease;
      flex-shrink: 0;
    }

    .link-arrow svg {
      width: 16px;
      height: 16px;
      stroke: var(--off-white);
      stroke-width: 2;
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .link-card a:hover .link-arrow {
      opacity: 1;
      transform: translateX(3px);
    }

    /* ── Footer ────────────────────────────────────── */
    .footer {
      opacity: 0;
      animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.8s forwards;
      text-align: center;
    }

    .footer-text {
      font-size: 0.7rem;
      color: rgba(245,245,240,0.2);
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    /* ── Decorative Lines ──────────────────────────── */
    .deco-line {
      position: fixed;
      background: var(--gradient);
      opacity: 0.06;
      z-index: 0;
    }

    .deco-line--left {
      width: 1px;
      height: 100vh;
      top: 0;
      left: 12%;
    }

    .deco-line--right {
      width: 1px;
      height: 100vh;
      top: 0;
      right: 12%;
    }

    .deco-line--h {
      height: 1px;
      width: 100vw;
      top: 20%;
      left: 0;
    }

    /* ── Animations ────────────────────────────────── */
    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* ── Responsive ────────────────────────────────── */
    @media (min-width: 480px) {
      .container { padding: 64px 24px 72px; }
      .logo-wrap { width: 110px; height: 110px; }
      .logo-circle { width: 110px; height: 110px; }
      .logo-x { font-size: 60px; }
      .profile-name { font-size: 2.4rem; }
    }

    @media (min-width: 768px) {
      .container { max-width: 460px; }
    }
  </style>
</head>
<body>

  <!-- Decorative lines -->
  <div class="deco-line deco-line--left"></div>
  <div class="deco-line deco-line--right"></div>
  <div class="deco-line deco-line--h"></div>

  <div class="container">

    <!-- Logo -->
    <div class="logo-wrap">
      <div class="logo-circle">
        <img src="/logo.png" alt="<%= profile.name %>">
      </div>
    </div>

    <!-- Profile -->
    <div class="profile">
      <h1 class="profile-name"><%= profile.name %></h1>
    </div>

    <hr class="divider">

    <!-- Links -->
    <div class="links">
      <% links.forEach(link => { %>
        <div class="link-card">
          <a href="<%= link.url %>" target="_blank" rel="noopener noreferrer">
            <div class="link-icon">
              <% if (link.icon === 'globe') { %>
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              <% } else if (link.icon === 'youtube') { %>
                <svg viewBox="0 0 24 24"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="currentColor" stroke="none"/></svg>
              <% } else if (link.icon === 'linkedin') { %>
                <svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              <% } else { %>
                <svg viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              <% } %>
            </div>
            <div class="link-text">
              <div class="link-title"><%= link.title %></div>
              <div class="link-desc"><%= link.description %></div>
            </div>
            <div class="link-arrow">
              <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
            </div>
          </a>
        </div>
      <% }) %>
    </div>

    <!-- Footer -->
    <div class="footer">
      <p class="footer-text">&copy; 2026 <%= profile.name %></p>
    </div>

  </div>

</body>
</html>
